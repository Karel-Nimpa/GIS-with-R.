#--------------------------------------------
    # 1. Setup and Data Preparation 
#--------------------------------------------
# Set your working directory to a folder designated for this project
setwd("C:/Users/yulia/Documents/R/PatternRecognition")

# Import your NDVI data, which will typically be in a TIFF format representing stacked monthly data.
filename <- "\\Julia\\Study in Germany_Trier University\\Pattern Recognition\\Portfolio\\Part_1\\GIMMS_monthly_1982-2022.tif"
ndvi_raster <- brick(filename)

# Extract the first 12 layers (first year: 1982)
ndvi_1982 <- subset(ndvi_raster, 1:12)

# Plot the first 12 months of 1982
plot(ndvi_1982, col=rev(terrain.colors(10)), legend=TRUE) 

#--------------------------------------------
     # 2. Data Manipulation 
#--------------------------------------------
# Convert the raster data into an array for easier manipulation.
cube <- as.array(ndvi_raster) #3D

# Prepare the data structure for storing the results of your trend analysis, specifically arrays 
# to store the Mann-Kendall tau and p-values for each pixel.
nrows <- nrow(cube) 
ncols <- ncol(cube) 

tau_array <- array(NA, c(nrows, ncols))
pval_array <- array(NA, c(nrows, ncols))
regcoeff <- array(NA, c(nrows, ncols)) 

#--------------------------------------------
    # 3. Trend Analysis 
#--------------------------------------------
# Implement the Seasonal Mann-Kendall test for each pixel across the time series data:
# For each pixel, extract the time-series data
# Ensure the time-series data is non-trivial (i.e., non-NA and has variance)
# Calculate the Mann-Kendall test statistic and p-value
# Store these results in your pre-defined arrays

# Initialize progress bar
pb <- winProgressBar(title = "progress bar", min = 0,max = nrows, width = 300)

start.time <- Sys.time() #how long does it take, just checking

# Loop through each pixel and calculate test statistics
for (i in 1:nrows) {
  setWinProgressBar(pb, i, title=paste( round(i/nrows*100, 0),"% done"))
  for (j in 1:ncols) {
    # Extract time-series for current pixel
    x <- cube[i, j, ] #copy time-series into x
    
    # Calculate Seasonal Mann-Kendall test statistics
    if (!is.na(x[1]) && var(x) > 0)
      {
        x <- ts(x,start=c(1983,1),frequency=12)
        res <- SeasonalMannKendall(ts(x)) 
        
        # Store p-value, tau statistic, and slope in arrays
        tau_array[i, j] <- res$tau
        pval_array[i, j] <- res$sl * as.numeric(sign(res$tau))
        time <- 1:dim(cube)[3]
        model <- lm(x~time)
        regcoeff[i, j] <- model$coefficients[2]
     }  
  }
}
close(pb)
end.time <- Sys.time()
time.taken <- end.time - start.time
time.taken


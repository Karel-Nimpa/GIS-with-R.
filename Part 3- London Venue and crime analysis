g <- gstat(g, id = c("mean_pollution", "mean_NOx"), model = cross_model)

# Fit Linear Model of Coregionalization
cat("  ‚Üí Fitting Linear Model of Coregionalization...\n")
lmc_model <- fit.lmc(variogram_cok, g)

# Perform cokriging

    as.numeric(logLik(lm_model)),
    as.numeric(logLik(lag_model)),
    as.numeric(logLik(error_model))
  ),
  Residual_Moran_I = c(
    unname(moran_lm$estimate[1]),
    unname(moran_lag$estimate[1]),
    unname(moran_error$estimate[1])
  ),
  Residual_Moran_p = c(
    moran_lm$p.value,

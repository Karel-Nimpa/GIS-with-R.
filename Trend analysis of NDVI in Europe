      RF <- RF[[1]][,3]
      
      model <- lm(VI ~ RF)
      
      #2. Arima-Model for residuals
      optfit <- auto.arima(model$residuals, max.p=5, max.q = 0)
      
      #3. Filter original series 
      yfiltered <- residuals(Arima(VI,model=optfit))
      xfiltered <- residuals(Arima(RF,model=optfit))
      
      # setup distributed lag models
      
      lagX1 <- Lag (as.numeric(xfiltered), 1)
      lagX2 <- Lag (as.numeric(xfiltered), 2)
      lagX3 <- Lag (as.numeric(xfiltered), 3)
      lagX4 <- Lag (as.numeric(xfiltered), 4)
      lagX5 <- Lag (as.numeric(xfiltered), 5)
      lagX6 <- Lag (as.numeric(xfiltered), 6)
      
      # 4. repeat OLS-regression 

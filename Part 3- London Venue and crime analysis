cat(sprintf("Minimum neighbours: %d\n", min(n_neigh)))
cat(sprintf("Maximum neighbours: %d\n", max(n_neigh)))
cat(sprintf("Mean neighbours: %.2f\n", mean(n_neigh)))
cat(sprintf("Median neighbours: %.2f\n", median(n_neigh)))

